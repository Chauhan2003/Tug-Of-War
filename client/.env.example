# ===== CLIENT ENVIRONMENT VARIABLES =====
# Copy this to .env for development or .env.production for production

# API Server URL
VITE_API_URL=http://localhost:3000/api

# WebSocket URL (optional - uses same domain as API)
# VITE_WS_URL=ws://localhost:3000

# App Configuration
VITE_APP_NAME=Tug of War Math Game
VITE_APP_VERSION=1.0.0

# Feature Flags
VITE_ENABLE_AI_FEATURES=true
VITE_ENABLE_MULTIPLAYER=true
VITE_ENABLE_LEADERBOARD=true

# Analytics (optional)
# VITE_GOOGLE_ANALYTICS_ID=your-ga-tracking-id

# Environment
VITE_NODE_ENV=development
